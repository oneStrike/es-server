{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2024",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "paths": {
      "@db/core": ["./db/core"],
      "@db/schema": ["./db/schema"],
      "@libs/platform/*": ["./libs/platform/src/*"],
      "@libs/app-content/*": ["./libs/app-content/src/*"],
      "@libs/account/*": ["./libs/account/src/*"],
      "@libs/app-config": ["./libs/config/src/app-config"],
      "@libs/app-config/*": ["./libs/config/src/app-config/*"],
      "@libs/config/*": ["./libs/config/src/*"],
      "@libs/dictionary": ["./libs/config/src/dictionary"],
      "@libs/dictionary/*": ["./libs/config/src/dictionary/*"],
      "@libs/forum/*": ["./libs/forum/src/*"],
      "@libs/growth/*": ["./libs/growth/src/*"],
      "@libs/content/*": ["./libs/content/src/*"],
      "@libs/eventing/*": ["./libs/eventing/src/*"],
      "@libs/sensitive-word": ["./libs/moderation/src"],
      "@libs/sensitive-word/*": ["./libs/moderation/src/*"],
      "@libs/growth/task": ["./libs/growth/src/task"],
      "@libs/growth/task/*": ["./libs/growth/src/task/*"],
      "@libs/interaction/*": ["./libs/interaction/src/*"],
      "@libs/message/*": ["./libs/message/src/*"],
      "@libs/observability/*": ["./libs/observability/src/*"],
      "@libs/user/*": ["./libs/user/src/*"],
      "@libs/workflow/*": ["./libs/workflow/src/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "strictBindCallApply": false,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": true,
    "declaration": false,
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "apps/**/*",
    "libs/**/*",
    "scripts/**/*",
    "src/**/*",
    "db/**/*",
    "*.ts"
  ],
  "exclude": ["node_modules", "dist", "test/**/*"]
}
