/// 用户通知表
/// 统一承载站内通知（回复/点赞/收藏/关注/系统消息）
model UserNotification {
  /// 主键ID
  id Int @id @default(autoincrement())

  /// 通知接收用户ID
  userId         Int       @map("user_id")
  /// 通知类型
  type           String    @db.VarChar(40)
  /// 幂等业务键（接收人维度）
  bizKey         String    @map("biz_key") @db.VarChar(160)
  /// 触发用户ID
  actorUserId    Int?      @map("actor_user_id")
  /// 目标类型
  targetType     Int?      @map("target_type") @db.SmallInt
  /// 目标ID
  targetId       Int?      @map("target_id")
  /// 主体类型
  subjectType    String?   @map("subject_type") @db.VarChar(40)
  /// 主体ID
  subjectId      Int?      @map("subject_id")
  /// 标题
  title          String    @db.VarChar(200)
  /// 内容
  content        String    @db.VarChar(1000)
  /// 扩展载荷
  payload        Json?     @db.JsonB
  /// 聚合键
  aggregateKey   String?   @map("aggregate_key") @db.VarChar(160)
  /// 聚合计数
  aggregateCount Int       @default(1) @map("aggregate_count")
  /// 已读标记
  isRead         Boolean   @default(false) @map("is_read")
  /// 已读时间
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  /// 过期时间
  expiredAt      DateTime? @map("expired_at") @db.Timestamptz(6)
  /// 创建时间
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  /// 接收用户
  user      AppUser  @relation("UserNotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  /// 触发用户
  actorUser AppUser? @relation("UserNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  /// 唯一约束：接收人维度幂等
  @@unique([userId, bizKey])
  /// 列表查询索引：按已读状态分组分页
  @@index([userId, isRead, createdAt(sort: Desc)])
  /// 列表查询索引：按时间分页
  @@index([userId, createdAt(sort: Desc)])
  /// 类型筛选索引
  @@index([type, createdAt(sort: Desc)])
  /// 聚合查询索引
  @@index([userId, aggregateKey, createdAt(sort: Desc)])
  @@map("user_notification")
}
