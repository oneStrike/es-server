/// 聊天消息表（仅私聊）
model ChatMessage {
  /// 主键ID
  id BigInt @id @default(autoincrement())

  /// 会话ID
  conversationId Int       @map("conversation_id")
  /// 会话内递增序号
  messageSeq     BigInt    @map("message_seq")
  /// 发送用户ID
  senderId       Int       @map("sender_id")
  /// 消息类型（TEXT/IMAGE/SYSTEM）
  messageType    Int       @map("message_type") @db.SmallInt
  /// 文本内容
  content        String    @db.Text
  /// 扩展载荷
  payload        Json?     @db.JsonB
  /// 消息状态（NORMAL/REVOKED/DELETED）
  status         Int       @db.SmallInt
  /// 创建时间
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 编辑时间
  editedAt       DateTime? @map("edited_at") @db.Timestamptz(6)
  /// 撤回时间
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)

  /// 所属会话
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// 发送用户
  sender       AppUser          @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  /// 会话内序号唯一
  @@unique([conversationId, messageSeq])
  /// 会话消息倒序分页索引
  @@index([conversationId, createdAt(sort: Desc)])
  /// 发送者审计索引
  @@index([senderId, createdAt(sort: Desc)])
  @@map("chat_message")
}
