/// 统一成长流水表
/// 记录积分、经验等可计量资产的变更流水
model GrowthLedgerRecord {
  /// 主键ID
  id          Int     @id @default(autoincrement())
  /// 用户ID
  userId      Int     @map("user_id")
  /// 资产类型（1=积分 2=经验值）
  assetType   Int     @map("asset_type") @db.SmallInt
  /// 变更值（正数发放，负数扣减）
  delta       Int
  /// 变更前余额
  beforeValue Int     @map("before_value")
  /// 变更后余额
  afterValue  Int     @map("after_value")
  /// 幂等业务键（同用户下全局唯一）
  bizKey      String  @map("biz_key") @db.VarChar(120)
  /// 规则类型（可选）
  ruleType    Int?    @map("rule_type") @db.SmallInt
  /// 规则ID（可选）
  ruleId      Int?    @map("rule_id")
  /// 目标类型（可选）
  targetType  Int?    @map("target_type") @db.SmallInt
  /// 目标ID（可选）
  targetId    Int?    @map("target_id")
  /// 备注
  remark      String? @db.VarChar(500)
  /// 扩展上下文
  context     Json?

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  /// 用户关联
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 幂等唯一约束：同一用户同一业务键只允许生效一次
  @@unique([userId, bizKey])
  /// 账单查询索引
  @@index([userId, assetType, createdAt])
  /// 目标检索索引
  @@index([targetType, targetId])
  @@map("growth_ledger_record")
}
