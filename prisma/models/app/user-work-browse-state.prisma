/// 用户作品浏览状态表
/// 用于保存用户对每个作品的最新浏览状态，和 user_view 历史记录分离。
model UserWorkBrowseState {
  /// 主键 ID
  id Int @id @default(autoincrement())

  /// 用户 ID
  userId Int @map("user_id")
  /// 作品 ID
  workId Int @map("work_id")
  /// 作品类型（1=漫画, 2=小说）
  workType Int @map("work_type") @db.SmallInt

  /// 最近一次打开作品详情的时间
  lastViewedAt DateTime @map("last_viewed_at") @db.Timestamptz(6)
  /// 最近一次浏览到的章节 ID，可用于继续阅读
  lastViewedChapterId Int? @map("last_viewed_chapter_id")

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// 关联用户
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 关联作品
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  /// 关联最近浏览章节
  lastViewedChapter WorkChapter? @relation("UserWorkBrowseStateLastViewedChapter", fields: [lastViewedChapterId], references: [id], onDelete: SetNull)

  /// 每个用户对每个作品只保留一条最新状态
  @@unique([userId, workId])
  /// 用户按类型查看最近浏览作品时使用
  @@index([userId, workType, lastViewedAt], map: "user_work_browse_state_user_id_work_type_last_viewed_at_idx")
  /// 作品维度查询浏览状态时使用
  @@index([workId])
  /// 继续阅读关联章节查询时使用
  @@index([lastViewedChapterId])
  @@map("user_work_browse_state")
}
