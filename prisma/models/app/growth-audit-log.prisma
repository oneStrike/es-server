/// 成长结算审计日志表
/// 记录规则判定与结算结果，便于排障和运营追踪
model GrowthAuditLog {
  /// 主键ID
  id Int @id @default(autoincrement())

  /// 请求链路ID（可选）
  requestId String? @map("request_id") @db.VarChar(80)
  /// 用户ID
  userId    Int     @map("user_id")

  /// 幂等业务键
  bizKey    String @map("biz_key") @db.VarChar(120)
  /// 资产类型（POINTS / EXPERIENCE / BADGE）
  assetType String @map("asset_type") @db.VarChar(30)
  /// 动作（GRANT / CONSUME / APPLY_RULE / ASSIGN_BADGE）
  action    String @db.VarChar(30)

  /// 规则类型（可选）
  ruleType Int?    @map("rule_type") @db.SmallInt
  /// 判定结果（allow / deny）
  decision String  @db.VarChar(20)
  /// 拒绝或处理原因
  reason   String? @db.VarChar(80)

  /// 请求变更值（可选）
  deltaRequested Int? @map("delta_requested")
  /// 实际变更值（可选）
  deltaApplied   Int? @map("delta_applied")

  /// 扩展上下文
  context Json?

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  /// 用户关联
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 业务键检索索引
  @@index([userId, bizKey])
  /// 判定统计索引
  @@index([assetType, action, decision, createdAt])
  /// 请求链路索引
  @@index([requestId])
  @@map("growth_audit_log")
}
