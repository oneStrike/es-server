/// 用户作品阅读状态表
/// 用于保存用户对作品（漫画/小说）的阅读进度状态
model UserWorkReadingState {
  /// 主键 ID
  id                Int      @id @default(autoincrement())
  /// 用户 ID
  userId            Int      @map("user_id")
  /// 作品 ID
  workId            Int      @map("work_id")
  /// 作品类型（1=漫画, 2=小说）
  workType          Int      @map("work_type") @db.SmallInt
  /// 最近一次阅读时间
  lastReadAt        DateTime @map("last_read_at") @db.Timestamptz(6)
  /// 最近一次阅读到的章节 ID，用于继续阅读
  lastReadChapterId Int?     @map("last_read_chapter_id")
  /// 创建时间
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  /// 关联用户
  user            AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 关联作品
  work            Work         @relation(fields: [workId], references: [id], onDelete: Cascade)
  /// 关联最近阅读章节
  lastReadChapter WorkChapter? @relation("UserWorkReadingStateLastReadChapter", fields: [lastReadChapterId], references: [id], onDelete: SetNull)

  /// 每个用户对每个作品只保留一条最新状态
  @@unique([userId, workId])
  /// 用户按类型查看最近阅读作品时使用
  @@index([userId, workType, lastReadAt])
  /// 作品维度查询阅读状态时使用
  @@index([workId])
  /// 继续阅读关联章节查询时使用
  @@index([lastReadChapterId])
  @@map("user_work_reading_state")
}
