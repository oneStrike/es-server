/// 应用用户表
/// 存储应用端用户信息及其关联关系
model AppUser {
  /// 用户ID
  id      Int     @id @default(autoincrement())
  /// 账号（唯一）
  account String  @unique @map("account") @db.VarChar(20)
  /// 手机号（唯一）
  phone   String? @unique @map("phone_number") @db.VarChar(20)
  /// 邮箱（唯一）
  email   String? @unique @map("email_address") @db.VarChar(255)

  /// 等级ID
  levelId Int? @map("level_id")

  /// 昵称
  nickname  String    @map("nickname") @db.VarChar(100)
  /// 密码（加密存储）
  password  String    @map("password") @db.VarChar(500)
  /// 头像URL
  avatar    String?   @map("avatar_url") @db.VarChar(500)
  /// 是否启用
  isEnabled Boolean   @default(true) @map("is_enabled")
  /// 性别（0=未知，1=男，2=女）
  gender    Int       @default(0) @map("gender_type") @db.SmallInt
  /// 出生日期
  birthDate DateTime? @map("birth_date") @db.Date

  /// 积分
  points     Int @default(0)
  /// 经验值
  experience Int @default(0)

  /// 用户状态
  status    Int       @default(1) @map("status")
  /// 封禁原因
  banReason String?   @map("ban_reason") @db.VarChar(500)
  /// 封禁到期时间
  banUntil  DateTime? @map("ban_until") @db.Timestamptz(6)

  /// 最后登录时间
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  /// 最后登录IP
  lastLoginIp String?   @map("last_login_ip") @db.VarChar(45)

  /// 创建时间
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  /// 更新时间
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  /// 删除时间（软删除）
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  /// 协议签署记录
  agreementLogs AppAgreementLog[]

  /// 等级规则关联
  level                   UserLevelRule?              @relation(fields: [levelId], references: [id])
  /// 论坛资料关联
  forumProfile            ForumProfile?
  /// 公告阅读记录
  announcementReads       AppAnnouncementRead[]
  /// 登录令牌
  tokens                  AppUserToken[]
  /// 发布的论坛主题
  forumTopics             ForumTopic[]                @relation("UserTopics")
  /// 最后回复的主题
  lastReplyTopics         ForumTopic[]                @relation("UserLastReplyTopics")
  /// 论坛通知
  forumNotifications      ForumNotification[]
  /// 通知接收记录
  receivedNotifications   UserNotification[]          @relation("UserNotificationReceiver")
  /// 通知触发记录
  triggeredNotifications  UserNotification[]          @relation("UserNotificationActor")
  /// 私聊会话成员记录
  chatConversationMembers ChatConversationMember[]    @relation("ChatConversationMemberUser")
  /// 私聊发送消息记录
  sentChatMessages        ChatMessage[]               @relation("ChatMessageSender")
  /// 私聊会话最后发言快照
  lastSentConversations   ChatConversation[]          @relation("ChatConversationLastSender")
  /// 版主申请（申请人）
  moderatorApplications   ForumModeratorApplication[] @relation("ModeratorApplicant")
  /// 版主申请（审核人）
  auditedApplications     ForumModeratorApplication[] @relation("ModeratorAuditor")
  /// 版主信息
  moderator               ForumModerator?
  /// 论坛行为日志
  forumActionLogs         ForumUserActionLog[]
  /// 用户徽章
  userBadges              UserBadgeAssignment[]
  /// 统一成长流水
  growthLedgerRecords     GrowthLedgerRecord[]
  /// 成长审计日志
  growthAuditLogs         GrowthAuditLog[]
  /// 规则限流槽位
  growthRuleUsageSlots    GrowthRuleUsageSlot[]
  /// 任务分配
  taskAssignments         TaskAssignment[]
  /// 任务进度日志
  taskProgressLogs        TaskProgressLog[]
  /// 更新的论坛配置
  updatedConfigs          ForumConfig[]               @relation("ForumConfigUpdater")
  /// 操作的论坛配置历史
  operatedConfigHistories ForumConfigHistory[]        @relation("ForumConfigHistoryOperator")

  /// 点赞记录
  userLikes           UserLike[]
  /// 收藏记录
  userFavorites       UserFavorite[]
  /// 浏览记录
  browseLogs          UserBrowseLog[]
  /// 作品阅读状态
  workReadingStates   UserWorkReadingState[]
  /// 评论记录
  userComments        UserComment[]
  /// 举报记录（举报人）
  userReports         UserReport[]           @relation("UserReportReporter")
  /// 举报记录（处理人）
  handledUserReports  UserReport[]           @relation("UserReportHandler")
  /// 下载记录
  userDownloadRecords UserDownloadRecord[]
  /// 购买记录
  userPurchaseRecords UserPurchaseRecord[]

  /// 启用状态索引
  @@index([isEnabled])
  /// 性别索引
  @@index([gender])
  /// 创建时间索引
  @@index([createdAt])
  /// 最后登录时间索引
  @@index([lastLoginAt])
  /// 手机号索引
  @@index([phone])
  /// 邮箱索引
  @@index([email])
  /// 积分索引
  @@index([points])
  /// 状态索引
  @@index([status])
  /// 等级索引
  @@index([levelId])
  @@map("app_user")
}
