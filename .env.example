################################################################################
# 必需配置 (Required Configuration)
# 缺失这些配置将导致服务无法启动
################################################################################

# 环境模式 (development | production)
NODE_ENV=production

SERVER_VERSION=0.0.2

# 数据库连接配置 (PostgreSQL)
# 容器内互联时使用服务名(postgres)，本地开发使用 localhost

DATABASE_URL=postgresql://es_db:change-me@postgres:5432/foo
REDIS_URL=redis://:change-me@redis:6379/0

# 仅对登记的本地 disposable target 执行 demo seed 时设置；禁止用于生产或共享数据库。
# ALLOW_DB_SEED=true

# PostgreSQL 连接预算。唯一公式：
# Σ(replicas_i × (queryPoolMax_i + listenerConnections_i))
#   + concurrentMigrators + opsHeadroom + superuserReserve <= max_connections
# `listenerConnections` 是专用 pg.Client（不是 query pool 槽位）；每个需要通知的
# 进程只能是 0 或 1。Compose 会为 admin-api/app-api 注入对应 DB_PROCESS_ROLE。
DB_MAX_CONNECTIONS=100
DB_ADMIN_API_REPLICAS=1
DB_ADMIN_API_POOL_MAX=20
DB_ADMIN_API_LISTENER_CONNECTIONS=0
DB_APP_API_REPLICAS=1
DB_APP_API_POOL_MAX=20
DB_APP_API_LISTENER_CONNECTIONS=1
DB_CONCURRENT_MIGRATORS=1
DB_OPS_HEADROOM=5
DB_SUPERUSER_RESERVE=3

# Query pool 生命周期边界：连接获取不会无限等待，空闲连接与最大寿命均受控。
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX_LIFETIME_SECONDS=1800

################################################################################
# 暴露策略 (Exposure Strategy)
# 生产 compose 默认只 expose 容器内端口给 1panel-network，由边缘 Nginx 统一暴露 80/443。
# 如需宿主机 Nginx 直连，请使用单独 compose override 绑定 127.0.0.1:端口:容器端口。
#
# 反向代理信任配置见 docs/architecture/reverse-proxy-trust.md。
# 当前 1panel-network 共享网络拓扑下，优先实测边缘代理 peer 后配置 TRUSTED_PROXY_IPS。
# 两个配置互斥；TRUST_PROXY_HOPS=1 只适用于 API 已不能被 1panel-network 任意容器直连的场景。
# TRUSTED_PROXY_IPS=172.18.0.1
# TRUST_PROXY_HOPS=1
################################################################################

################################################################################
# 上传文件本地存储 (Upload Storage)
# files 服务只读挂载同一个 uploads 根目录，并仅暴露 /app/uploads/public 下的文件。
################################################################################

UPLOAD_LOCAL_DIR=/app/uploads/public
UPLOAD_TMP_DIR=/app/uploads/tmp
UPLOAD_LOCAL_URL_PREFIX=/files

################################################################################
# Admin 服务特定配置 (Admin Configuration)
################################################################################

# JWT 配置
ADMIN_JWT_EXPIRATION_IN=4h
ADMIN_JWT_REFRESH_EXPIRATION_IN=7d
ADMIN_JWT_ISSUER=es-admin
ADMIN_JWT_JWT_AUD="admin"

# Redis 命名空间
ADMIN_REDIS_NAMESPACE=ES_ADMIN

# 文件上传
ADMIN_UPLOAD_MAX_FILE_SIZE=100MB

################################################################################
# App 服务特定配置 (App Configuration)
################################################################################

# JWT 配置
APP_JWT_EXPIRATION_IN=7d
APP_JWT_REFRESH_EXPIRATION_IN=30d
APP_JWT_ISSUER=es-app
APP_JWT_JWT_AUD="app"

# Redis 命名空间
APP_REDIS_NAMESPACE=ES_APP

# 聊天历史分页签名密钥：使用至少 32 字符的高熵随机值，轮换会使已有历史分页游标失效。
CHAT_MESSAGE_CURSOR_SECRET=change-me-to-a-random-secret-with-at-least-32-characters

# 文件上传
APP_UPLOAD_MAX_FILE_SIZE=100MB

# App 版本
APP_APP_VERSION=1.0.0

################################################################################
# 推荐配置 (Recommended Configuration)
################################################################################

# 时区设置 (Docker 容器推荐设置)
TZ=Asia/Shanghai

# 日志配置
LOG_LEVEL=info
LOG_CONSOLE_LEVEL=info

# 可选：宿主机/命名卷持久目录。JWT/RSA 密钥必须持久化，否则每次重建容器都会让旧登录态失效。
# HOST_UPLOADS_DIR=es-server-uploads
# HOST_LOGS_DIR=es-server-logs
# HOST_ADMIN_SECRETS_DIR=es-admin-server-secrets
# HOST_APP_SECRETS_DIR=es-app-server-secrets

################################################################################
# IP 属地库配置 (IP Geolocation)
################################################################################

# 管理端上传与当前进程热切换使用的专用存储目录
IP2REGION_DATA_DIR=./uploads/ip2region

# 可选：手动指定单文件 xdb 路径；未配置时优先使用 active 目录中的当前生效文件
# IP2REGION_XDB_PATH=./db/resources/ip2region/ip2region_v4.xdb
