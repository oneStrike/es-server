################################################################################
# 必需配置 (Required Configuration)
# 缺失这些配置将导致服务无法启动
################################################################################

# 环境模式 (development | production)
NODE_ENV=production

# 数据库连接配置 (PostgreSQL)
# docker-compose 会基于下列 DB_* 变量组装容器内的 DATABASE_URL
# DATABASE_URL 保留给本地 drizzle / seed 命令使用
DB_HOST=1Panel-postgresql-VSCP
DB_PORT=5432
DB_USER=es_db
DB_PASSWORD=FRxaeR2GD6ETP73n
DB_NAME=es_db
DATABASE_URL=postgresql://es_db:FRxaeR2GD6ETP73n@1Panel-postgresql-VSCP:5432/es_db
DB_WAIT_TIMEOUT_MS=120000
DB_WAIT_INTERVAL_MS=2000
DB_SEED=false

REDIS_URL=redis://:redis_pM5Z5P@1Panel-redis-wfeq:6379/0

################################################################################
# 端口配置 (Port Configuration)
# 用于 docker-compose.yml 的端口映射
################################################################################

# Admin API 宿主机映射端口
ADMIN_API_PORT=8080

# App API 宿主机映射端口
APP_API_PORT=8081

# 前端 Admin 宿主机映射端口
ADMIN_PORT=8082

# 前端 Admin 宿主机映射端口
APP_WEB_PORT=8083

################################################################################
# Admin 服务特定配置 (Admin Configuration)
################################################################################

# JWT 配置
ADMIN_JWT_EXPIRATION_IN=4h
ADMIN_JWT_REFRESH_EXPIRATION_IN=7d
ADMIN_JWT_ISSUER=es-admin

# Redis 命名空间
ADMIN_REDIS_NAMESPACE=ES_ADMIN

# 文件上传 (默认: ./uploads/admin)
ADMIN_UPLOAD_DIR=./uploads/admin
ADMIN_UPLOAD_MAX_FILE_SIZE=100MB

################################################################################
# App 服务特定配置 (App Configuration)
################################################################################

# JWT 配置
APP_JWT_EXPIRATION_IN=7d
APP_JWT_REFRESH_EXPIRATION_IN=30d
APP_JWT_ISSUER=es-app

# Redis 命名空间
APP_REDIS_NAMESPACE=ES_APP

# 文件上传 (默认: ./uploads/app)
APP_UPLOAD_DIR=./uploads/app
APP_UPLOAD_MAX_FILE_SIZE=100MB

# App 版本与资源前缀
APP_APP_VERSION=1.0.0
APP_APP_FILE_URL_PREFIX=/files

################################################################################
# 推荐配置 (Recommended Configuration)
################################################################################

# 时区设置 (Docker 容器推荐设置)
TZ=Asia/Shanghai

# 日志配置
LOG_LEVEL=info
LOG_CONSOLE_LEVEL=info
