{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/admin-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "webpack",
    "tsConfigPath": "apps/admin-api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/admin-api",
  "projects": {
    "admin-api": {
      "type": "application",
      "root": "apps/admin-api",
      "entryFile": "main",
      "sourceRoot": "apps/admin-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/admin-api/tsconfig.app.json"
      }
    },
    "app-api": {
      "type": "application",
      "root": "apps/app-api",
      "entryFile": "main",
      "sourceRoot": "apps/app-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/app-api/tsconfig.app.json"
      }
    }
  }
}
