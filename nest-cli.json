{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/admin-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "webpack",
    "tsConfigPath": "apps/admin-api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/admin-api",
  "projects": {
    "admin-api": {
      "type": "application",
      "root": "apps/admin-api",
      "entryFile": "main",
      "sourceRoot": "apps/admin-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/admin-api/tsconfig.app.json"
      }
    },
    "app-api": {
      "type": "application",
      "root": "apps/app-api",
      "entryFile": "main",
      "sourceRoot": "apps/app-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/app-api/tsconfig.app.json"
      }
    },
    "platform": {
      "type": "library",
      "root": "libs/platform",
      "entryFile": "index",
      "sourceRoot": "libs/platform/src",
      "compilerOptions": {
        "tsConfigPath": "libs/platform/tsconfig.lib.json"
      }
    },
    "app-content": {
      "type": "library",
      "root": "libs/app-content",
      "entryFile": "index",
      "sourceRoot": "libs/app-content/src",
      "compilerOptions": {
        "tsConfigPath": "libs/app-content/tsconfig.lib.json"
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "content": {
      "type": "library",
      "root": "libs/content",
      "entryFile": "index",
      "sourceRoot": "libs/content/src",
      "compilerOptions": {
        "tsConfigPath": "libs/content/tsconfig.lib.json"
      }
    },
    "forum": {
      "type": "library",
      "root": "libs/forum",
      "entryFile": "index",
      "sourceRoot": "libs/forum/src",
      "compilerOptions": {
        "tsConfigPath": "libs/forum/tsconfig.lib.json"
      }
    },
    "message": {
      "type": "library",
      "root": "libs/message",
      "entryFile": "index",
      "sourceRoot": "libs/message/src",
      "compilerOptions": {
        "tsConfigPath": "libs/message/tsconfig.lib.json"
      }
    },
    "growth": {
      "type": "library",
      "root": "libs/growth",
      "entryFile": "index",
      "sourceRoot": "libs/growth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/growth/tsconfig.lib.json"
      }
    }
  }
}
