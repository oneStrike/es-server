    "drizzle-orm": "1.0.0-rc.4",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "file-type": "^22.0.1",
    "image-size": "^2.0.2",
    "ip2region.js": "3.1.8",
    "joi": "^18.2.3",
    "keyv": "^5.6.0",
    "mime-types": "^3.0.2",
    "nest-winston": "1.10.2",
    "nestjs-cls": "^6.2.1",
    "node-cron": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "qiniu": "^7.15.2",
    "reflect-metadata": "^0.2.2",
