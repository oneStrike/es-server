  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-rc.3",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.3",
    "run-script-webpack-plugin": "^0.2.3",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^7.2.2",
    "tree-kill": "^1.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-node-externals": "^3.0.0"
  },
